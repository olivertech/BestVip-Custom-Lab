@page
@model BestVipCustomLab.Web.Pages.SurveyModel
@{
    ViewData["Title"] = "Pesquisa";
    var campaign = Model.Campaign;
}

@if (campaign is null)
{
    <section class="container surface-card stack-lg">
        <h1>Sem campanha ativa.</h1>
    </section>
}
else
{
    <section class="container stack-lg">
        <div class="surface-card stack-md">
            <span class="eyebrow">Pesquisa da campanha</span>
            <h1>@campaign.Name</h1>
            <p>@campaign.Subheadline</p>
            @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
            {
                <p class="success-badge">@Model.SuccessMessage</p>
            }
        </div>

        <form method="post" class="surface-card survey-form stack-lg">
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
            <input asp-for="Input.VisitorId" type="hidden" />

            @for (var index = 0; index < campaign.Questions.Count; index++)
            {
                var question = campaign.Questions[index];
                <input name="Input.Answers[@index].QuestionId" type="hidden" value="@question.Id" />
                <section class="survey-question">
                    <div class="stack-sm">
                        <h3>@question.Prompt</h3>
                        <p>@question.HelpText</p>
                    </div>

                    @if (question.Type == BestVipCustomLab.Domain.SurveyQuestionType.Text)
                    {
                        <textarea class="survey-textarea" name="Input.Answers[@index].Value" rows="5" placeholder="Escreva sua resposta com liberdade."></textarea>
                    }
                    else
                    {
                        <div class="option-grid">
                            @foreach (var option in question.Options)
                            {
                                <label class="choice-card">
                                    <input
                                        type="radio"
                                        name="Input.Answers[@index].Value"
                                        value="@option.Label" />
                                    <span class="choice-card-body">
                                        <span class="choice-indicator"></span>
                                        <span class="choice-label">@option.Label</span>
                                    </span>
                                </label>
                            }
                        </div>
                    }
                </section>
            }

            <button class="button button-primary" type="submit">Enviar pesquisa</button>
        </form>
    </section>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
