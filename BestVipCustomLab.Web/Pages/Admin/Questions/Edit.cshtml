@page
@model BestVipCustomLab.Web.Pages.Admin.Questions.EditModel
@{
    ViewData["Title"] = "Editar Pergunta";
}

<section class="container stack-lg">
    <form method="post" class="surface-card stack-md">
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
        <input asp-for="Input.Id" type="hidden" />
        <input asp-for="Input.CampaignId" type="hidden" />
        <label><span>Pergunta</span><input asp-for="Input.Prompt" /></label>
        <label><span>Ajuda</span><textarea asp-for="Input.HelpText" rows="3"></textarea></label>
        <label><span>Tipo</span><select asp-for="Input.Type" asp-items="Html.GetEnumSelectList<BestVipCustomLab.Domain.SurveyQuestionType>()"></select></label>
        <label><span>Ordem</span><input asp-for="Input.DisplayOrder" type="number" /></label>
        <label class="checkbox"><input asp-for="Input.IsRequired" /> Obrigatoria</label>
        <label><span>Opcoes (uma por linha)</span><textarea asp-for="Input.OptionsText" rows="8"></textarea></label>
        <button class="button button-primary" type="submit">Salvar pergunta</button>
    </form>
</section>
