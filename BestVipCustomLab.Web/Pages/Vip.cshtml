@page
@model BestVipCustomLab.Web.Pages.VipModel
@{
    ViewData["Title"] = "Lista VIP";
}

<section class="container form-layout">
    <div class="surface-card stack-md">
        <span class="eyebrow">Lista VIP</span>
        <h1>Segmentação premium por campanha.</h1>
        <p>Entre na lista da campanha vigente para receber avisos de lançamento, mockups e possíveis pré-vendas.</p>
    </div>

    <form method="post" class="surface-card stack-md">
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
        <input asp-for="Input.CampaignId" type="hidden" />
        <input asp-for="Input.VisitorId" type="hidden" />
        <label><span>O que mais te interessa nesta campanha?</span><textarea asp-for="Input.Notes" rows="5"></textarea></label>
        <button class="button button-primary" type="submit">Entrar na Lista VIP</button>
        @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
        {
            <p class="success-badge">@Model.SuccessMessage</p>
        }
    </form>
</section>
